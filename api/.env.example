# .env.example
# Copy this file to .env and fill in the values for production.
# This file stores sensitive configuration data.
APP_ENV=production
APP_URL=https://your-domain.com
FRONTEND_URL=https://your-domain.com

# Site Identity
SITE_NAME=ElectrCom
SITE_EMAIL=electrocom@gmail.com
PHONE1=0536683393
PHONE2=0506408074
WHATSAPP=0536683393

# Site Assets
SITE_LOGO_URL=\uploads\branding\logo_6a1ea7b89e41a.png
FAVICON_URL=\uploads\branding\logo_6a1ea7b89e41a.png

# Database
DB_HOST=localhost
DB_USER=db_user
DB_PASS=db_password
DB_NAME=electrocom
DB_AUTO_REPAIR=false

# Security & Encryption
JWT_SECRET=generate_a_64+_character_random_string
PASSWORD_PEPPER=generate_a_random_string
DATA_ENCRYPTION_KEY=generate_a_32_character_random_key

# Payment: Paystack
PAYSTACK_SECRET=your_paystack_secret_key_here

# Social Login: Google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT=https://api.your-domain.com/social_auth.php?provider=google

# Social Login: Github
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_REDIRECT=https://api.your-domain.com/social_auth.php?provider=github

# Notification: Email (SMTP-first, no paid provider required)
EMAIL_PROVIDER=smtp
EMAIL_QUEUE_ENABLED=true
EMAIL_MAX_ATTEMPTS=5
EMAIL_SMTP_ENABLED=true
EMAIL_MAILGUN_ENABLED=false
EMAIL_SENDGRID_ENABLED=false
MAIL_FROM_NAME=EssentialsHub
MAIL_FROM=no-reply@your-domain.com
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_ENCRYPTION=tls

# Optional paid providers (set EMAIL_PROVIDER=mailgun or sendgrid)
MAILGUN_API_KEY=
MAILGUN_DOMAIN=
MAILGUN_REGION=us
SENDGRID_API_KEY=

# Notification: SMS (Hubtel)
SMS_CLIENT_ID=
SMS_CLIENT_SECRET=
SMS_FROM=
SMS_API_URL=https://smsc.hubtel.com/v1/messages/send

# Thresholds & Business Logic
ELITE_THRESHOLD=500
VIP_THRESHOLD=2000

# CORS & Image Security (comma-separated lists)
ALLOWED_ORIGINS="https://your-domain.com,https://admin.your-domain.com"
ALLOWED_IMAGE_BASES="https://your-domain.com/api/,https://your-domain.com/"
